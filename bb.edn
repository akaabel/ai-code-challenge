{:paths ["ops"]

 :tasks
 {:requires ([nrepl-eval :refer [nrepl-eval print-result]]
             [babashka.process :refer [shell]])

  build
  {:doc "Build the robotfund container image (tag: robotfund:latest)"
   :task (shell "podman build -t robotfund .")}

  run
  {:doc "Run the robotfund container — reads ~/fund/.env, mounts ~/fund/xtdb-data"
   :task (let [home (System/getProperty "user.home")]
           (shell "podman" "run" "-d" "--name" "robotfund"
                  "--env-file" (str home "/fund/.env")
                  "-p" "8080:8080"
                  "-v" (str home "/fund/xtdb-data:/data/xtdb:Z")
                  "robotfund:latest"))}

  stop
  {:doc "Stop and remove the robotfund container"
   :task (shell "podman" "rm" "-f" "robotfund")}

  help
  {:doc "List all tasks with their remote-call profile (LLM / Alpaca / local)"
   :override-builtin true
   :task (do
           (println)
           (println "Available bb tasks")
           (println)
           (println "CONTAINER")
           (println "  bb build            Build the robotfund container image (tag: robotfund:latest)")
           (println "  bb run              Run the container — reads ~/fund/.env, mounts ~/fund/xtdb-data")
           (println "  bb stop             Stop and remove the running container")
           (println)
           (println "PIPELINE AGENTS  (each writes results to XTDB)")
           (println "  bb scan             [Alpaca]        Discover today's movers + most-actives via Alpaca screener,")
           (println "                                      flag price-change >1.5% or volume-spike >2×, write :candidate")
           (println "  bb news             [Alpaca + LLM]  Fetch headlines per candidate from Alpaca news API,")
           (println "                                      score sentiment via Gemini, write :news-report")
           (println "  bb analyse          [LLM]           Rate each candidate 1–10 and recommend buy/sell/hold")
           (println "                                      via Gemini, write :analysis")
           (println "  bb risk             [Alpaca]        Apply hard Clojure rules (10% position cap, 30% sector cap,")
           (println "                                      ≤5 trades/day, min rating 7 to buy), write :trade-proposal")
           (println "  bb execute          [Alpaca]        Place approved proposals as Alpaca market orders,")
           (println "                                      reconcile fills, cancel stale orders, write :order + :fill")
           (println "  bb pipeline         [Alpaca + LLM]  Full pipeline: scan → news → analyse → risk → execute")
           (println)
           (println "QUERIES  (read-only, local XTDB — no remote calls)")
           (println "  bb reports          [local]         All :news-report entries — ticker, sentiment score, summary")
           (println "  bb analyses         [local]         All :analysis entries — ticker, rating, action, reasoning")
           (println "  bb proposals        [local]         All :trade-proposal entries — ticker, action, decision, reason")
           (println)
           (println "PORTFOLIO")
           (println "  bb sector-exposure  [Alpaca]        Live portfolio breakdown — market value and % of equity")
           (println "                                      per sector bucket (incl. :other for unknown tickers)")
           (println))}

  scan
  {:doc "Run scanner — finds price-change and volume-spike candidates, writes :candidate to XTDB"
   :task (print-result
          (nrepl-eval "(require '[com.robotfund.agents.scanner :as scanner]
                                '[repl :refer [get-context]])
                       (scanner/run-scanner (get-context))"))}

  news
  {:doc "Run news agent — fetches Alpaca headlines, scores sentiment via LLM, writes :news-report to XTDB"
   :task (print-result
          (nrepl-eval "(require '[com.robotfund.agents.news :as news]
                                '[repl :refer [get-context]])
                       (news/run-news-agent (get-context))"))}

  analyse
  {:doc "Run analyst agent — rates each candidate (1–10), recommends buy/sell/hold, writes :analysis to XTDB"
   :task (print-result
          (nrepl-eval "(require '[com.robotfund.agents.analyst :as analyst]
                                '[repl :refer [get-context]])
                       (analyst/run-analyst (get-context))"))}

  reports
  {:doc "Query XTDB — print all :news-report entries (ticker, sentiment, summary)"
   :task (print-result
          (nrepl-eval "(require '[xtdb.api :as xt]
                                '[repl :refer [get-context]])
                       (mapv first (xt/q (xt/db (:biff.xtdb/node (get-context)))
                                         '{:find  [(pull r [:news-report/ticker
                                                            :news-report/sentiment
                                                            :news-report/summary])]
                                           :where [[r :news-report/ticker]]}))"))}

  analyses
  {:doc "Query XTDB — print all :analysis entries (ticker, rating, action, reasoning)"
   :task (print-result
          (nrepl-eval "(require '[xtdb.api :as xt]
                                '[repl :refer [get-context]])
                       (mapv first (xt/q (xt/db (:biff.xtdb/node (get-context)))
                                         '{:find  [(pull a [:analysis/ticker
                                                            :analysis/rating
                                                            :analysis/action
                                                            :analysis/reasoning])]
                                           :where [[a :analysis/ticker]]}))"))}

  risk
  {:doc "Run risk manager — applies hard rules, writes :trade-proposal (approved/resized/rejected) to XTDB"
   :task (print-result
          (nrepl-eval "(require '[com.robotfund.agents.risk :as risk]
                                '[repl :refer [get-context]])
                       (risk/run-risk (get-context))"))}

  proposals
  {:doc "Query XTDB — print all :trade-proposal entries (ticker, action, decision, reason)"
   :task (print-result
          (nrepl-eval "(require '[xtdb.api :as xt]
                                '[repl :refer [get-context]])
                       (mapv first (xt/q (xt/db (:biff.xtdb/node (get-context)))
                                         '{:find  [(pull p [:trade-proposal/ticker
                                                            :trade-proposal/action
                                                            :trade-proposal/quantity
                                                            :trade-proposal/decision
                                                            :trade-proposal/reason])]
                                           :where [[p :trade-proposal/ticker]]}))"))}

  execute
  {:doc "Run executor — places approved proposals as Alpaca market orders, reconciles fills, cancels stale orders"
   :task (print-result
          (nrepl-eval "(require '[com.robotfund.agents.executor :as executor]
                                '[repl :refer [get-context]])
                       (executor/run-executor (get-context))"))}

  sector-exposure
  {:doc "Show current portfolio sector breakdown (market value + % of equity per sector bucket)"
   :task (print-result
          (nrepl-eval "(require '[com.robotfund.alpaca :as alpaca]
                                '[com.robotfund.agents.risk :as risk])
                       (let [account   (alpaca/get-account)
                             positions (alpaca/get-positions)
                             equity    (Double/parseDouble (str (:equity account)))
                             by-sector (group-by #(get risk/sector-map (:symbol %) :other) positions)]
                         (into (sorted-map)
                               (map (fn [[sector pos]]
                                      [sector
                                       (let [mv (reduce + 0.0 (map #(Double/parseDouble (str (:market_value %))) pos))]
                                         {:pct     (double (Math/round (* 100.0 (/ mv equity))))
                                          :value   (long mv)
                                          :tickers (mapv :symbol pos)})])
                                    by-sector)))"))}

  pipeline
  {:doc "Run full pipeline: scan → news → analyse → risk → execute"
   :task (print-result
          (nrepl-eval "(require '[com.robotfund.agents.scanner  :as scanner]
                                '[com.robotfund.agents.news     :as news]
                                '[com.robotfund.agents.analyst  :as analyst]
                                '[com.robotfund.agents.risk     :as risk]
                                '[com.robotfund.agents.executor :as executor]
                                '[repl :refer [get-context]])
                       (let [ctx (get-context)]
                         {:candidates (scanner/run-scanner ctx)
                          :reports    (news/run-news-agent ctx)
                          :analyses   (analyst/run-analyst ctx)
                          :proposals  (risk/run-risk ctx)
                          :orders     (executor/run-executor ctx)})"))}}}
